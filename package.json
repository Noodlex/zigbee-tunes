{
  "name": "zigbee-tunes",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Zigbee Tunes — Z2M Discovery Manager. Normalizes MQTT Discovery payloads between Zigbee2MQTT and Home Assistant.",
  "license": "MIT",
  "author": "Noodlex",
  "homepage": "https://github.com/Noodlex/zigbee-tunes",
  "repository": {
    "type": "git",
    "url": "https://github.com/Noodlex/zigbee-tunes.git"
  },
  "bugs": {
    "url": "https://github.com/Noodlex/zigbee-tunes/issues"
  },
  "packageManager": "yarn@4.15.0",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "start:built": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "ui:install": "cd ui && yarn install",
    "ui:dev": "cd ui && yarn dev",
    "ui:build": "cd ui && yarn build",
    "build:all": "yarn build && yarn ui:build"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.1.0",
    "mqtt": "^5.10.1",
    "winston": "^3.17.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3"
  }
}
